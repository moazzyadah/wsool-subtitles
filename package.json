{
  "name": "wsool-subtitles",
  "version": "0.1.0",
  "private": true,
  "description": "Universal multi-provider video subtitle generator with 14 STT providers and Egyptian Arabic dialect support",
  "license": "MIT",
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1",
    "dev:lan": "next dev --hostname 0.0.0.0",
    "build": "next build",
    "start": "next start --hostname 127.0.0.1",
    "start:lan": "next start --hostname 0.0.0.0",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "smoke:libass": "node scripts/smoke-libass.mjs",
    "fonts:download": "node scripts/download-fonts.mjs"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "better-sqlite3": "^11.3.0",
    "dotenv": "^16.4.5",
    "file-type": "^19.6.0",
    "fluent-ffmpeg": "^2.1.3",
    "framer-motion": "^11.11.17",
    "lucide-react": "^0.460.0",
    "next": "^14.2.18",
    "openai": "^4.73.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-dropzone": "^14.3.5",
    "server-only": "^0.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^20.17.6",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.18",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
