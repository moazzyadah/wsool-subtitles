{
  "name": "wsool-subtitles",
  "version": "0.1.0",
  "private": true,
  "description": "Universal multi-provider video subtitle generator with 14 STT providers and Egyptian Arabic dialect support",
  "license": "MIT",
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1",
    "dev:lan": "next dev --hostname 0.0.0.0",
    "build": "next build",
    "start": "next start --hostname 127.0.0.1",
    "start:lan": "next start --hostname 0.0.0.0",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "smoke:libass": "node scripts/smoke-libass.mjs",
    "fonts:download": "node scripts/download-fonts.mjs"
  },
  "dependencies": {
    "@ffmpeg-installer/ffmpeg": "^1.1.0",
    "@tailwindcss/postcss": "^4.2.4",
    "better-sqlite3": "^12.9.0",
    "clsx": "2.1.1",
    "dotenv": "^17.4.2",
    "file-type": "^22.0.1",
    "fluent-ffmpeg": "^2.1.3",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.11.0",
    "next": "^16.2.4",
    "openai": "^6.34.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-dropzone": "^15.0.0",
    "server-only": "^0.0.1",
    "tailwind-merge": "3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^22.19.17",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "postcss": "^8.4.49",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
