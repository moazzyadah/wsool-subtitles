# =====================================================================
#  wsool-subtitles — environment configuration
# =====================================================================
#
#  Copy this file to .env and fill in the keys for the providers you
#  want to use. The app gracefully disables providers whose key is
#  missing — no error, they just don't appear in the UI dropdown.
#
#  You can also run with ZERO API keys using the built-in Local
#  whisper.cpp provider (downloads a model on first use).
#
# ---------------------------------------------------------------------
#  Cheap/fast Whisper (free dev tier — 7,200s/day)
# ---------------------------------------------------------------------
GROQ_API_KEY=                # https://console.groq.com/keys
OPENAI_API_KEY=              # https://platform.openai.com/api-keys
TOGETHER_API_KEY=            # $1 free credit — https://api.together.xyz/settings/api-keys
FIREWORKS_API_KEY=           # https://fireworks.ai/account/api-keys
FAL_KEY=                     # https://fal.ai/dashboard/keys

# ---------------------------------------------------------------------
#  Run any HuggingFace Whisper checkpoint (incl. Egyptian fine-tunes)
# ---------------------------------------------------------------------
REPLICATE_API_TOKEN=         # https://replicate.com/account/api-tokens
HF_TOKEN=                    # https://huggingface.co/settings/tokens

# ---------------------------------------------------------------------
#  Production-grade Arabic (incl. Egyptian dialect)
# ---------------------------------------------------------------------
DEEPGRAM_API_KEY=            # $200 credit — https://console.deepgram.com/
SPEECHMATICS_API_KEY=        # 8h/mo free — https://portal.speechmatics.com/
SONIOX_API_KEY=              # $200 credit — https://console.soniox.com/
ASSEMBLYAI_API_KEY=          # $50 credit — https://www.assemblyai.com/app/account
ELEVENLABS_API_KEY=          # https://elevenlabs.io/app/settings/api-keys
GEMINI_API_KEY=              # free tier — https://aistudio.google.com/app/apikey

# =====================================================================
#  Safety knobs (sane defaults — change only if you know why)
# =====================================================================
MAX_UPLOAD_MB=2048
MAX_DURATION_SEC=10800
JOBS_RETENTION_DAYS=7

# Set true to allow non-localhost binding (e.g., LAN access). DANGEROUS
# without auth — anyone on your network can submit jobs and burn your
# provider credits. Default: false.
ALLOW_LAN=false

# Optional: use a system FFmpeg instead of the bundled binary.
# Required if the bundled binary lacks libass (Arabic glyph rendering).
FFMPEG_PATH=

# Local Whisper: directory where ggml models are downloaded.
# Default: ./models inside the project.
LOCAL_WHISPER_MODELS_DIR=
